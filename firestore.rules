rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Global security helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Diagnostic connection test endpoint
    match /test/connection {
      allow read: if true;
    }

    // User document path
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && request.resource.data.uid == userId;
      allow update: if isOwner(userId) && isValidId(userId);
      allow delete: if false; // Deny deleting raw user logs

      // User Meals collection
      match /meals/{mealId} {
        allow read, write: if isOwner(userId) && isValidId(mealId);
      }

      // User Workouts collection
      match /workouts/{workoutId} {
        allow read, write: if isOwner(userId) && isValidId(workoutId);
      }

      // User Water consumption logs
      match /waterLogs/{waterLogId} {
        allow read, write: if isOwner(userId) && isValidId(waterLogId);
      }
    }
  }
}
